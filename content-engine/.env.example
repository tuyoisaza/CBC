# ─── Anthropic (Claude) ───────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── OpenAI (DALL-E 3 image generation) ───────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Meta / Facebook Graph API ────────────────────────────────
# Get these from: developers.facebook.com → your app → permissions
META_ACCESS_TOKEN=your_long_lived_page_access_token
META_INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id
META_FACEBOOK_PAGE_ID=your_facebook_page_id

# ─── LinkedIn API ─────────────────────────────────────────────
# Get from: linkedin.com/developers → your app
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_URN=urn:li:person:your_person_id
# Or for company page:
LINKEDIN_ORGANIZATION_URN=urn:li:organization:your_org_id

# ─── WhatsApp Business Cloud API ──────────────────────────────
# Get from: developers.facebook.com → WhatsApp → API Setup
WHATSAPP_TOKEN=your_whatsapp_business_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=a_random_string_you_choose_for_webhook_verification
# Lorena's personal phone (to authorize her commands)
LORENA_PHONE=521XXXXXXXXXX

# ─── App ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
