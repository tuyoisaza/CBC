# ─────────────────────────────────────────────────────────────────────────────
# CBC Platform — Environment Variables Template
# Copy this file to .env.local for local development.
# For Railway: set each variable in Railway dashboard → service → Variables.
#
# [AUTO]    injected automatically by Railway (reference another service)
# [GEN]     pre-generated value — see docs/strategy/railway-env-vars.md
# [COLLECT] must be obtained from the listed third-party dashboard
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://coffeebunncafe.com
NEXT_PUBLIC_ADMIN_URL=https://admin.coffeebunncafe.com

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://admin.coffeebunncafe.com
NEXTAUTH_SECRET=                        # [GEN] openssl rand -hex 32
ADMIN_EMAIL=contact@coffeebunncafe.com
ADMIN_PASSWORD_HASH=                    # [GEN] see railway-env-vars.md

# ─── Database ─────────────────────────────────────────────────────────────────
# [AUTO] Railway → Variables → Add Reference → Postgres → DATABASE_URL
DATABASE_URL=postgresql://user:pass@host:5432/db

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# console.cloud.google.com → Credentials → OAuth 2.0 Client (Web)
# Authorized redirect URI: https://admin.coffeebunncafe.com/api/auth/callback/google
GOOGLE_CLIENT_ID=                        # [COLLECT]
GOOGLE_CLIENT_SECRET=                    # [COLLECT]

# ─── Internal services ────────────────────────────────────────────────────────
# Shared secret between web ↔ engine (x-engine-token header, timing-safe compared)
ENGINE_SECRET_TOKEN=                     # [GEN]
CBC_ENGINE_URL=https://cbc-engine.railway.internal
# Engine-only: base URL of the web platform (coffee reads, Post writeback, R2 images)
# Prefer Railway private networking so token traffic stays internal.
PLATFORM_URL=https://cbc-web.railway.internal

# ─── Email (Brevo preferred, Resend fallback) ─────────────────────────────────
# Set ONE provider key. Brevo free tier: 300 emails/day (brevo.com → SMTP & API
# → API Keys). If BREVO_API_KEY is set it takes precedence over Resend.
BREVO_API_KEY=                           # [COLLECT] brevo.com
RESEND_API_KEY=                          # [COLLECT] resend.com (optional fallback)
EMAIL_FROM=hola@coffeebunncafe.com       # sender address (must be verified in the provider)
RESEND_FROM_EMAIL=hola@coffeebunncafe.com # legacy alias, kept for existing deploys

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
# developers.facebook.com → WhatsApp → API Setup
WHATSAPP_TOKEN=                          # [COLLECT]
WHATSAPP_PHONE_NUMBER_ID=               # [COLLECT]
WHATSAPP_VERIFY_TOKEN=                   # [GEN] first 32 chars of ENGINE_SECRET_TOKEN
# App secret used to verify X-Hub-Signature-256 on inbound webhooks.
# Falls back to META_APP_SECRET if unset. REQUIRED in production —
# without it the webhook only warns and skips signature verification.
WHATSAPP_APP_SECRET=                     # [COLLECT] same app → Settings → Basic
LORENA_PHONE=5215572293512

# ─── Meta / Instagram / Facebook ─────────────────────────────────────────────
# PREFERRED: connect via Admin → Marketing → Conexiones (OAuth, tokens in DB).
# That flow needs only META_APP_ID + META_APP_SECRET on the web service, with
# redirect URI https://coffeebunncafe.com/api/auth/social/meta/callback
# registered in the Meta app (Facebook Login → Settings).
META_APP_ID=                             # [COLLECT] developers.facebook.com → app → Settings → Basic
META_APP_SECRET=                         # [COLLECT] same page
# Legacy fallback (engine env vars, used only if nothing connected in admin):
META_ACCESS_TOKEN=                       # [COLLECT] optional
META_INSTAGRAM_ACCOUNT_ID=              # [COLLECT] optional
META_FACEBOOK_PAGE_ID=                  # [COLLECT] optional

# ─── LinkedIn ─────────────────────────────────────────────────────────────────
# PREFERRED: connect via Admin → Marketing → Conexiones (OAuth, tokens in DB).
# That flow needs only LINKEDIN_CLIENT_ID + LINKEDIN_CLIENT_SECRET on the web
# service, with redirect URI
# https://coffeebunncafe.com/api/auth/social/linkedin/callback registered in
# the LinkedIn app (Auth → Redirect URLs). Scopes: openid profile w_member_social.
LINKEDIN_CLIENT_ID=                      # [COLLECT] linkedin.com/developers → app → Auth
LINKEDIN_CLIENT_SECRET=                  # [COLLECT] same page
# Legacy fallback (engine env vars, used only if nothing connected in admin):
LINKEDIN_ACCESS_TOKEN=                   # [COLLECT] optional
LINKEDIN_PERSON_URN=urn:li:person:       # [COLLECT] optional
LINKEDIN_ORGANIZATION_URN=               # [COLLECT] optional — company page takes precedence

# ─── Stripe ───────────────────────────────────────────────────────────────────
# stripe.com → Developers → API Keys + Webhooks
# Register webhook: https://coffeebunncafe.com/api/webhooks/stripe
# Events: checkout.session.completed
STRIPE_SECRET_KEY=sk_live_              # [COLLECT]
STRIPE_PUBLISHABLE_KEY=pk_live_         # [COLLECT]
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_  # [COLLECT] same value as above
STRIPE_WEBHOOK_SECRET=whsec_            # [COLLECT]

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-               # [COLLECT] console.anthropic.com
OPENAI_API_KEY=sk-                      # [COLLECT] platform.openai.com (DALL-E images)

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
# cloudflare.com → R2 → Manage API Tokens
CLOUDFLARE_R2_ACCOUNT_ID=              # [COLLECT]
CLOUDFLARE_R2_ACCESS_KEY=              # [COLLECT]
CLOUDFLARE_R2_SECRET_KEY=              # [COLLECT]
CLOUDFLARE_R2_BUCKET=cbc-assets
NEXT_PUBLIC_R2_PUBLIC_URL=https://assets.coffeebunncafe.com

# ─── SAT / CFDI (Facturapi) ───────────────────────────────────────────────────
# facturapi.io → API Keys
FACTURAPI_KEY=sk_live_                  # [COLLECT]
CBC_RFC=                                 # [COLLECT] RFC from SAT
CBC_RAZON_SOCIAL=COFFEE BUNN CAFE
CBC_REGIMEN_FISCAL=601
CBC_CODIGO_POSTAL_FISCAL=11800
CBC_CSD_CERT_BASE64=                    # [COLLECT] base64 of .cer file from SAT
CBC_CSD_KEY_BASE64=                     # [COLLECT] base64 of .key file from SAT
CBC_CSD_PASSWORD=                       # [COLLECT]

# ─── Monitoring (optional) ────────────────────────────────────────────────────
SENTRY_DSN=                             # [COLLECT] sentry.io
NEXT_PUBLIC_POSTHOG_KEY=               # [COLLECT] app.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
