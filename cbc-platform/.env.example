# Copy to .env.local for development

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3000

# Database (get from Railway PostgreSQL add-on)
DATABASE_URL=postgresql://user:password@localhost:5432/cbc

# Auth
NEXTAUTH_SECRET=change-this-to-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=contact@coffeebunncafe.com
ADMIN_PASSWORD_HASH=                    # bcrypt hash of your password

# Stripe (get from stripe.com/dashboard)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# SAT / Facturapi (get from facturapi.io)
FACTURAPI_KEY=sk_test_...
CBC_RFC=
CBC_RAZON_SOCIAL=
CBC_REGIMEN_FISCAL=601
CBC_CODIGO_POSTAL_FISCAL=
CBC_CSD_CERT_BASE64=
CBC_CSD_KEY_BASE64=
CBC_CSD_PASSWORD=

# AI
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Meta (developers.facebook.com)
META_ACCESS_TOKEN=
META_INSTAGRAM_ACCOUNT_ID=
META_FACEBOOK_PAGE_ID=
META_APP_SECRET=

# LinkedIn (linkedin.com/developers)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:...

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=choose-a-random-string
LORENA_PHONE=521XXXXXXXXXX

# Email (resend.com)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hola@coffeebunncafe.com

# Cloudflare R2 (cloudflare.com/r2)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=cbc-assets
NEXT_PUBLIC_R2_PUBLIC_URL=https://assets.coffeebunncafe.com

# Monitoring (optional in dev)
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
