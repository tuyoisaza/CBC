---
import Layout from '../../layouts/Layout.astro';

const WA_URL = 'https://wa.me/5215572293512?text=Hello%2C%20I%20want%20to%20quote%20CBC%20gift%20boxes';
---

<Layout 
  title="Coffee Bunn Café | Corporate Coffee Gifts"
  description="Premium corporate gifts with Mexican specialty coffee. Elevate your brand experience."
>
  <main>
    <!-- HERO SECTION -->
    <section class="relative overflow-hidden min-h-[90vh] flex items-center cbc-gradient">
      <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
        <div class="max-w-2xl animate-fade-in">
          <p class="mb-6 text-sm font-semibold tracking-widest uppercase text-cbc-yellow">
            B2B / Corporate Gifts
          </p>
          <h1 class="text-5xl font-bold leading-tight tracking-tight sm:text-6xl lg:text-7xl">
            Elevate Your <span class="text-cbc-yellow">Brand</span> Experience
          </h1>
          <p class="mt-6 text-xl leading-relaxed text-gray-400">
            Premium corporate gifts featuring Mexican specialty coffee. We design custom boxes that your clients and team will truly remember.
          </p>
          
          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <a
              href={WA_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 rounded-md bg-cbc-yellow px-8 py-4 text-base font-semibold text-black hover:bg-cbc-yellow/90 transition-all hover:shadow-lg focus-visible:ring-2 focus-visible:ring-cbc-yellow"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Talk to Sales
            </a>
            <a
              href="/en/cotizar"
              class="inline-flex items-center justify-center rounded-md border border-cbc-yellow/40 px-8 py-4 text-base font-semibold text-cbc-yellow hover:bg-cbc-yellow/10 transition-colors"
            >
              View B2B Catalog
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- PROMISE SECTION -->
    <section class="py-24 bg-cbc-black">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
          <div>
            <h3 class="text-xl font-bold text-cbc-yellow mb-4">Specialty Coffee</h3>
            <p class="text-gray-400">We source the best beans from Mexico, roasted on demand to guarantee peak freshness.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold text-cbc-yellow mb-4">Custom Design</h3>
            <p class="text-gray-400">Your logo and branding elegantly integrated into every element of the gift box.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold text-cbc-yellow mb-4">End-to-End Logistics</h3>
            <p class="text-gray-400">We deliver in volume to your offices or directly to the doorstep of every client.</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t border-gray-800 bg-[#1a1a1a] py-12">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 text-center text-gray-500">
      <p>&copy; {new Date().getFullYear()} Coffee Bunn Café. All rights reserved.</p>
      <div class="mt-4 flex justify-center gap-4">
        <a href="https://admin.coffeebunncafe.com" class="hover:text-cbc-yellow transition-colors">Admin Portal</a>
      </div>
    </div>
  </footer>
</Layout>
